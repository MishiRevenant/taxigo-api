{
    "name": "taxigo-api",
    "version": "2.0.0",
    "description": "TaxiGo REST API – Express + TypeScript + TypeORM + PostgreSQL + JWT + WebSockets",
    "type": "commonjs",
    "main": "dist/index.js",
    "scripts": {
        "dev": "node --require reflect-metadata -r ts-node/register src/index.ts",
        "dev:watch": "ts-node-dev --respawn --transpile-only --require reflect-metadata src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "seed": "npm run build && node dist/db/seed.js",
        "migration:run": "npm run build && node dist/db/migration-run.js",
        "migration:generate": "typeorm migration:generate src/migrations/Migration -d dist/config/database.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "socket.io": "^4.7.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "typeorm": "^0.3.20",
        "winston": "^3.13.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@swc/core": "^1.15.40",
        "@swc/helpers": "^0.5.23",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.25",
        "@types/pg": "^8.18.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.7.2",
        "typescript": "^5.4.2"
    }
}
